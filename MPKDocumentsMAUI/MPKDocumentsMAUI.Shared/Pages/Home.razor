        public string Author { get; set; } = "";
        public string StatusText { get; set; } = "";
        public string StatusClass { get; set; } = "";
        public bool HasViewed { get; set; }
        public bool HasChevron { get; set; }
        public DateTime ReceivedAt { get; set; }
        public int SignProgress { get; set; }
        public int SignTotal { get; set; }
        public bool IsSent { get; set; }
        public bool WaitingForOthers { get; set; }
        public int RecipientsViewed { get; set; }
        public int RecipientsTotal { get; set; }
        public IReadOnlyList<string> RecipientsViewedNames { get; set; } = Array.Empty<string>();
        public bool SuppressUnreadIndicator { get; set; }
    }
