    private void OnHostFileFromNative(string pathOrName, long size)
    {
        var trimmed = pathOrName.Trim();
        var name = Path.GetFileName(trimmed.TrimEnd(Path.DirectorySeparatorChar, Path.AltDirectorySeparatorChar));
        if (string.IsNullOrWhiteSpace(name)) return;
        var ext = (Path.GetExtension(name) ?? "").ToLowerInvariant();
        if (ext is not ".pdf" and not ".doc" and not ".docx") return;
        _ = InvokeAsync(async () =>
        {
            _pickedFileBytes = null;
            await ApplyPickedFileAsync(name, size);
        });
    }

