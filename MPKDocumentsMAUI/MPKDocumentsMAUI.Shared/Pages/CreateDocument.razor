    private async Task TryRestorePrecategoryFromStorageAsync()
    {
        if (_pendingResumeDraftId is not null) return;
        if (selectedTemplateId is not null) return;
        try
        {
            var json = await JS.InvokeAsync<string?>("MPKDocuments.storageGet", PrecatStorageKey);
            if (string.IsNullOrWhiteSpace(json)) return;
            using var doc = JsonDocument.Parse(json);
            var root = doc.RootElement;
            if (root.TryGetProperty("category", out var c) && c.ValueKind == JsonValueKind.String)
                selectedCategory = c.GetString();
            if (root.TryGetProperty("step", out var s) && s.TryGetInt32(out var st))
                currentStep = st is >= 0 and <= 1 ? st : 0;
            if (string.IsNullOrWhiteSpace(selectedCategory))
                currentStep = 0;
        }
        catch
        {
            // ignore
        }
    }

    private async Task SavePrecategoryToStorageAsync()
    {
        if (string.IsNullOrWhiteSpace(selectedCategory)) return;
        if (currentStep > 1) return;
        try
        {
            var json = JsonSerializer.Serialize(new { category = selectedCategory, step = currentStep });
            await JS.InvokeVoidAsync("MPKDocuments.storageSet", PrecatStorageKey, json);
        }
        catch
        {
            // ignore
        }
    }

    private async Task ClearPrecategoryStorageAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("MPKDocuments.storageRemove", PrecatStorageKey);
        }
        catch
        {
            // ignore
        }
    }

    private Dictionary<string, object?> BuildDraftContentForApi()
    {
        var c = BuildContent();
        c.Remove("otpCode");
        c["wizardStep"] = currentStep;
        if (!string.IsNullOrWhiteSpace(selectedCategory))
            c["wizardSelectedCategory"] = selectedCategory;
        return c;
    }

    private bool HasMeaningfulWizardProgress() =>
        selectedTemplateId is not null
        || (currentStep >= 1 && !string.IsNullOrWhiteSpace(selectedCategory));

    private async Task SaveWizardDraftIfNeededCoreAsync(bool throwOnFailure = false)
    {
        if (_suppressDraftSave || isSaving) return;
        if (!HasMeaningfulWizardProgress()) return;
        if (_draftSaveInFlight) return;
        if (selectedTemplateId is null)
        {
            await SavePrecategoryToStorageAsync();
            return;
        }

        _draftSaveInFlight = true;
        try
        {
            var payload = BuildDraftContentForApi();
            if (_draftDocumentId is int existingId)
            {
                await DocsApi.UpdateDraftContentAsync(existingId, payload);
            }
            else
            {
                var res = await DocsApi.CreateDocumentAsync(
                    selectedTemplateId.Value,
                    payload,
                    selectedSigners.ToList(),
                    signerDepartmentId: assignMode == AssignMode.Department ? selectedDepartmentId : null,
                    saveAsDraft: true);
                _draftDocumentId = res.document_id;
            }

            if (_pickedFileBytes is { Length: > 0 } && _draftDocumentId is int did)
                await UploadAttachmentIfNeededAsync(did);

            await ClearPrecategoryStorageAsync();
        }
        catch (Exception)
        {
            if (throwOnFailure)
                throw;
        }
        finally
        {
            _draftSaveInFlight = false;
        }
    }

    private async Task ResumeDraftFromServerAsync(int draftId)
    {
        if (meId is null) return;
        isLoading = true;
        loadError = null;
        try
        {
            var d = await DocsApi.GetDetailAsync(draftId);
            if (!string.Equals(d.status, "DRAFT", StringComparison.OrdinalIgnoreCase))
            {
                loadError = "Этот документ не в статусе черновика.";
                return;
            }

            if (d.initiator_id != meId.Value)
            {
                loadError = "Чужой черновик открыть нельзя.";
                return;
            }

            _resumeInProgress = true;
            _draftDocumentId = draftId;
            selectedTemplateId = d.template_id;
            selectedCategory = TryGetWizardCategory(d.content) ?? InferCategoryFromName(d.template_name);

            var detail = await DocsApi.GetTemplateAsync(d.template_id);
            FillSchemaFieldsFromFormSchema(detail);

            content = new();
            if (d.content is not null)
            {
                foreach (var kv in d.content)
                {
                    if (IsWizardMetaKey(kv.Key)) continue;
                    if (string.Equals(kv.Key, "signerUserIds", StringComparison.OrdinalIgnoreCase)) continue;
                    content[kv.Key] = NormalizeJsonValue(kv.Value);
                }
            }

            selectedSigners.Clear();
            if (d.content is not null && d.content.TryGetValue("signerUserIds", out var sjv))
            {
                if (sjv is JsonElement arr && arr.ValueKind == JsonValueKind.Array)
                {
                    foreach (var el in arr.EnumerateArray())
                    {
                        if (el.TryGetInt32(out var sid)) selectedSigners.Add(sid);
                    }
                }
            }

            if (d.content is not null && d.content.TryGetValue("assignMode", out var am))
            {
                var mode = NormalizeJsonValue(am)?.ToString();
                assignMode = string.Equals(mode, "department", StringComparison.OrdinalIgnoreCase)
                    ? AssignMode.Department
                    : AssignMode.Users;
            }

            if (d.content is not null && d.content.TryGetValue("signerDepartmentId", out var deptId))
            {
                var n = NormalizeJsonValue(deptId);
                if (n is long ll) selectedDepartmentId = (int)ll;
                else if (n is int ii) selectedDepartmentId = ii;
                else if (n is JsonElement je && je.ValueKind == JsonValueKind.Number && je.TryGetInt32(out var di))
                    selectedDepartmentId = di;
            }

            if (d.content is not null && d.content.TryGetValue("requiresPersonalSign", out var rps))
            {
                var v = NormalizeJsonValue(rps);
                requiresPersonalSign = v is bool b ? b : v?.ToString() is "true" or "True";
            }

            if (d.content is not null && d.content.TryGetValue("docDate", out var dd) && NormalizeJsonValue(dd) is string ds &&
                DateTime.TryParse(ds, CultureInfo.InvariantCulture, DateTimeStyles.None, out var parsed))
                docDate = parsed.Date;

            if (d.content is not null && d.content.TryGetValue("note", out var noteEl))
                docNote = NormalizeJsonValue(noteEl)?.ToString() ?? "";

            fileName = content.TryGetValue("fileName", out var fn) ? fn?.ToString() ?? "" : "";
            PickedFileName = fileName;
            if (d.content is not null && d.content.TryGetValue("fileSize", out var fsz))
            {
                var n = NormalizeJsonValue(fsz);
                if (n is long l) PickedFileSizeBytes = l;
                else if (n is int i) PickedFileSizeBytes = i;
                else if (n is JsonElement je && je.ValueKind == JsonValueKind.Number && je.TryGetInt64(out var lb))
                    PickedFileSizeBytes = lb;
            }

            var step = 2;
            if (d.content is not null && d.content.TryGetValue("wizardStep", out var ws))
            {
                var n = NormalizeJsonValue(ws);
                if (n is int i) step = i;
                else if (n is long l) step = (int)l;
                else if (n is JsonElement je && je.ValueKind == JsonValueKind.Number && je.TryGetInt32(out var wi))
                    step = wi;
            }

            currentStep = Math.Clamp(step, 0, 4);

            if (d.has_file_attachment)
            {
                try
                {
                    var (body, _) = await DocsApi.DownloadDocumentFileAsync(draftId);
                    _pickedFileBytes = body;
                }
                catch
                {
                    _pickedFileBytes = null;
                }
            }

            // Если в черновике уже есть файл (или имя в контенте), не оставляем на шаге «Загрузить файл» (2):
            // старые черновики без wizardStep или с шагом 2 после загрузки файла иначе снова показывали зону загрузки.
            var hasFileOnRecord = d.has_file_attachment
                || (_pickedFileBytes is { Length: > 0 })
                || !string.IsNullOrWhiteSpace(fileName);
            if (hasFileOnRecord && currentStep == 2)
                currentStep = 3;

            Navigation.NavigateTo("/create-document", replace: true);
        }
        catch
        {
            loadError = "Не удалось восстановить черновик.";
        }
        finally
        {
            _resumeInProgress = false;
            isLoading = false;
        }
    }

    private static string? TryGetWizardCategory(Dictionary<string, object?>? c)
    {
        if (c is null || !c.TryGetValue("wizardSelectedCategory", out var v)) return null;
        return NormalizeJsonValue(v)?.ToString();
    }

    private static bool IsWizardMetaKey(string key) =>
        string.Equals(key, "wizardStep", StringComparison.OrdinalIgnoreCase)
        || string.Equals(key, "wizardSelectedCategory", StringComparison.OrdinalIgnoreCase);

    private static object? NormalizeJsonValue(object? v)
    {
        if (v is JsonElement je)
        {
            return je.ValueKind switch
            {
                JsonValueKind.String => je.GetString(),
                JsonValueKind.Number => je.TryGetInt64(out var l) ? l : je.GetDouble(),
                JsonValueKind.True => true,
                JsonValueKind.False => false,
                JsonValueKind.Null => null,
                JsonValueKind.Array => je,
                JsonValueKind.Object => je,
                _ => je.GetRawText(),
            };
        }

        return v;
    }
}
