    private async Task EnsureFileDropAsync()
    {
        try
        {
            await TeardownFileDropAsync();
            // Не использовать "./_content/..." — на маршрутах вроде /create-document это даёт неверный путь
            // (/create-document/_content/...) и динамический import падает молча.
            var moduleUrl = Navigation.ToAbsoluteUri("_content/MPKDocumentsMAUI.Shared/mpk-fileDrop.js").ToString();
            _dropModule ??= await JS.InvokeAsync<IJSObjectReference>("import", moduleUrl);
            _dotNetRef ??= DotNetObjectReference.Create(this);
            _dropDisposeHandle = await _dropModule.InvokeAsync<IJSObjectReference>("initFileDrop", _dotNetRef, _dropZoneRef);
        }
        catch (JSDisconnectedException)
        {
        }
        catch (JSException)
        {
        }
    }

    private async Task TeardownFileDropAsync()
    {
        // Снимаем поле сразу, иначе при параллельном вызове (OnAfterRender + DisposeAsync)
        // после первого await второй поток видит null — NullReferenceException на DisposeAsync.
        var handle = Interlocked.Exchange(ref _dropDisposeHandle, null);
        if (handle is null)
            return;
        try
        {
            await handle.InvokeVoidAsync("dispose");
        }
        catch
        {
            // ignored
        }

        try
        {
            await handle.DisposeAsync();
        }
        catch
        {
            // ignored
        }
    }

    async ValueTask IAsyncDisposable.DisposeAsync()
    {
        _locationChangingRegistration?.Dispose();
        _locationChangingRegistration = null;
        ClearHostFileDropCallback();
        await TeardownFileDropAsync();
        _dotNetRef?.Dispose();
        _dotNetRef = null;
        if (_dropModule is not null)
        {
            try
            {
                await _dropModule.DisposeAsync();
            }
            catch
            {
                // ignored
            }

            _dropModule = null;
        }
    }

    private string? PickedFileName { get; set; }
    private long? PickedFileSizeBytes { get; set; }
    private string PickedFileSizeText => PickedFileSizeBytes is null ? "—" : FormatBytes(PickedFileSizeBytes.Value);
    private string? PickedFileExt => string.IsNullOrWhiteSpace(PickedFileName) ? null : Path.GetExtension(PickedFileName);

    private const int MaxUploadBytes = 25 * 1024 * 1024;
    private byte[]? _pickedFileBytes;

    private static string GuessMimeForFilename(string name)
    {
        return (Path.GetExtension(name) ?? "").ToLowerInvariant() switch
        {
            ".pdf" => "application/pdf",
            ".doc" => "application/msword",
            ".docx" => "application/vnd.openxmlformats-officedocument.wordprocessingml.document",
            _ => "application/octet-stream",
        };
    }

    private async Task UploadAttachmentIfNeededAsync(int documentId)
    {
        if (_pickedFileBytes is not { Length: > 0 }) return;
        if (string.IsNullOrWhiteSpace(fileName)) return;
        await using var ms = new MemoryStream(_pickedFileBytes);
        await DocsApi.UploadDocumentFileAsync(documentId, ms, fileName, GuessMimeForFilename(fileName));
    }

    private static string FormatBytes(long bytes)
    {
        string[] units = ["B", "KB", "MB", "GB"];
        double size = bytes;
        var unit = 0;
        while (size >= 1024 && unit < units.Length - 1)
        {
            size /= 1024;
            unit++;
        }
        return unit switch
        {
            0 => $"{bytes} {units[unit]}",
            _ => $"{size:0.##} {units[unit]}",
        };
    }

    private string GetFieldValue(string name) => content.TryGetValue(name, out var v) ? (v?.ToString() ?? "") : "";
    private void SetFieldValue(string name, string value) => content[name] = value;
