    private static int? TryParseDraftIdFromUri(string? uri)
    {
        if (string.IsNullOrEmpty(uri)) return null;
        var idx = uri.IndexOf("draft=", StringComparison.OrdinalIgnoreCase);
        if (idx < 0) return null;
        var start = idx + 6;
        var end = start;
        while (end < uri.Length && char.IsDigit(uri[end])) end++;
        if (end == start) return null;
        return int.TryParse(uri.AsSpan(start, end - start), out var id) ? id : null;
    }

    private static bool IsLeavingCreateWizard(string? target)
    {
        if (string.IsNullOrEmpty(target)) return true;
        return !target.Contains("/create-document", StringComparison.OrdinalIgnoreCase);
    }

    private async ValueTask OnLocationChangingAsync(LocationChangingContext ctx)
    {
        if (_suppressDraftSave) return;
        if (!IsLeavingCreateWizard(ctx.TargetLocation)) return;
        if (!HasMeaningfulWizardProgress()) return;
        if (showLeaveDraftModal) return;

        _leaveNavigationTarget = ctx.TargetLocation;
        leaveModalError = null;
        ctx.PreventNavigation();
        showLeaveDraftModal = true;
        await InvokeAsync(StateHasChanged);
    }

    private static string ToNavigatorUri(string? target)
    {
        if (string.IsNullOrWhiteSpace(target)) return "/";
        if (Uri.TryCreate(target, UriKind.Absolute, out var abs))
        {
            var p = abs.PathAndQuery;
            return string.IsNullOrEmpty(p) ? "/" : p;
        }

        return target.StartsWith('/') ? target : "/" + target;
    }

