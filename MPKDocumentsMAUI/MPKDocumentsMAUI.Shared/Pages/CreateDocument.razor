@page "/create-document"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@implements IAsyncDisposable
@inject NavigationManager Navigation
@inject MPKDocumentsMAUI.Shared.Api.DocumentsApiClient DocsApi
@inject MPKDocumentsMAUI.Shared.Api.AuthApiClient AuthApi
@using System.IO
@using System.Security.Claims
@using MPKDocumentsMAUI.Shared.Api
@using Microsoft.AspNetCore.Components.Authorization
@inject AuthenticationStateProvider AuthStateProvider
@inject MPKDocumentsMAUI.Shared.Services.IDocumentFilePicker DocumentFilePicker
@using MPKDocumentsMAUI.Shared.Services
@using Microsoft.AspNetCore.Components.Routing
@using System.Text.Json
@using System.Globalization
@inject IJSRuntime JS

<PageTitle>Создание нового документа — МПК Документы</PageTitle>

<div class="page-content">
    <h1 class="page-title">@TitleText</h1>

    @if (!string.IsNullOrWhiteSpace(loadError))
    {
        <div style="margin: 8px 0 12px;color:var(--text-secondary)">@loadError</div>
    }

    @if (isLoading)
    {
        <div class="mpk-page-loading"><LoadingSpinner Center /></div>
    }
    else
    {

    @* Step 0: Choose category *@
    @if (currentStep == 0)
    {
        <p class="wizard-subtitle">Выберите категорию документа:</p>
        <div class="category-grid">
            @foreach (var c in Categories)
            {
                <div class="category-card @(selectedCategory == c ? "selected" : "")"
                     @onclick="() => SelectCategoryAsync(c)">
                    <div class="category-card-icon">
                        <img src="icons/document.png" alt="" style="width:40px;height:48px;object-fit:contain;opacity:0.85" />
                    </div>
                    <div class="category-card-name">@c</div>
                </div>
            }
        </div>
    }

    @* Step 1: Choose type in category *@
    @if (currentStep == 1)
    {
        <div class="wizard-subtitle" style="margin-top:0">Категория: @selectedCategory</div>
        <div style="margin-bottom: 12px;">
            <button type="button" class="btn btn-secondary btn-sm" @onclick="GoPickCategory">
                Сменить категорию
            </button>
        </div>
        <p class="wizard-subtitle" style="margin-top:-6px">Выберите тип документа:</p>
        <div class="category-grid">
            @foreach (var t in TemplatesInCategory)
            {
                <div class="category-card @(selectedTemplateId == t.Id ? "selected" : "")"
                     @onclick="() => SelectTemplate(t.Id)">
                    <div class="category-card-icon">
                        <img src="icons/document.png" alt="" style="width:40px;height:48px;object-fit:contain;opacity:0.85" />
                    </div>
                    <div class="category-card-name">@t.Name</div>
                </div>
            }
        </div>
    }

    @* Step 2: Upload file *@
    @if (currentStep == 2)
    {
        <div class="wizard-subtitle" style="margin-top:0">@selectedCategory | @SelectedTemplateName</div>
        <div style="margin-bottom: 12px;">
            <button type="button" class="btn btn-secondary btn-sm" @onclick="GoPickType">
                Сменить тип
            </button>
        </div>
        <div class="category-grid" style="grid-template-columns: 1fr; width: 100%; max-width: 100%;">
            <div @ref="_dropZoneRef"
                 class="category-card mpk-file-drop @(_dragOverFile ? "mpk-file-drop--over" : null)"
                 style="width:100%;max-width:none;min-height: calc(100vh - 260px);border-style:dashed;border-width:2px;opacity:0.95;justify-content:center"
                 @ondragenter="OnFileDragEnter"
                 @ondragenter:preventDefault
                 @ondragleave="OnFileDragLeave"
                 @ondragover:preventDefault
                 @ondragover="OnFileDragOver">
                <div class="category-card-icon" style="margin-top:0">
                    <img src="icons/document.png" alt="" style="width:64px;height:64px;object-fit:contain;opacity:0.7" />
                </div>
                <div class="category-card-name" style="margin-top:14px">Загрузить файл</div>
                <div style="margin-top:8px;color:var(--text-secondary);font-size:12px;line-height:1.3;text-align:center;max-width:320px">
                    Загрузить файл с компьютера.<br />Выберите файл документа с расширением .doc, .docx или .pdf.<br />
                    Можно перетащить файл в эту область.
                </div>
                <div style="margin-top:14px">
                    @if (DocumentFilePicker.SupportsNativePick)
                    {
                        <button type="button" class="btn btn-secondary mpk-inputfile" @onclick="PickDocumentNativeAsync">
                            Выбрать файл…
                        </button>
                    }
                    else
                    {
                        <InputFile class="mpk-inputfile" OnChange="OnFileSelected" accept=".pdf,.doc,.docx" />
                    }
                </div>
                @if (!string.IsNullOrWhiteSpace(PickedFileName))
                {
                    <div style="margin-top:10px;color:var(--text-secondary);font-size:12px">
                        @PickedFileName (@PickedFileSizeText)
                    </div>
                }
            </div>
        </div>
    }

    @* Step 3: Sending (like slide 2) *@
    @if (currentStep == 3)
    {
        <p class="wizard-subtitle">@SelectedTemplateName</p>
        <div class="wizard-form">
            @if (schemaFields.Count > 0)
            {
                <div class="form-group">
                    <label class="form-label">Параметры документа</label>
                    <div style="margin-top:8px;color:var(--text-tertiary);font-size:12px">
                        Заполни данные по выбранному типу документа.
                    </div>
                </div>

                @foreach (var f in schemaFields)
                {
                    @* Чтобы не было двух "названий": title/fileName берём из общего поля ниже *@
                    if (string.Equals(f.Name, "title", StringComparison.OrdinalIgnoreCase) ||
                        string.Equals(f.Name, "fileName", StringComparison.OrdinalIgnoreCase))
                    {
                        continue;
                    }
                    <div class="form-group" style="margin-top: 12px;">
                        <label class="form-label">@GetUiLabel(f)@(f.Required ? " *" : "")</label>

                        @if (f.Type == "select" && f.Options is not null && f.Options.Count > 0)
                        {
                            @if (f.Options.Count >= 3)
                            {
                                <div class="category-grid" style="margin-top:8px;grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));">
                                    @foreach (var opt in f.Options)
                                    {
                                        <div class="category-card @(GetFieldValue(f.Name) == opt ? "selected" : "")"
                                             style="padding:14px 12px;gap:10px;min-height:96px"
                                             @onclick="() => SetFieldValue(f.Name, opt)">
                                            <div class="category-card-icon" style="width:40px;height:40px;opacity:0.9">
                                                <img src="icons/document.png" alt="" style="width:32px;height:32px;object-fit:contain;opacity:0.85" />
                                            </div>
                                            <div class="category-card-name" style="font-size:12px;line-height:1.2">@opt</div>
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                                <select class="form-input" style="margin-top:8px"
                                        value="@GetFieldValue(f.Name)"
                                        @onchange="(e) => OnFieldInput(e, f.Name)">
                                    <option value="">Выберите...</option>
                                    @foreach (var opt in f.Options)
                                    {
                                        <option value="@opt">@opt</option>
                                    }
                                </select>
                            }
                        }
                        else if (f.Type == "date")
                        {
                            <input class="form-input" type="date" style="margin-top:8px"
                                   value="@GetFieldValue(f.Name)"
                                   @oninput="(e) => OnFieldInput(e, f.Name)" />
                        }
                        else if (f.Type == "number")
                        {
                            <input class="form-input" type="number" style="margin-top:8px"
                                   placeholder="@f.Placeholder"
                                   value="@GetFieldValue(f.Name)"
                                   @oninput="(e) => OnFieldInput(e, f.Name)" />
                        }
                        else if (f.Multiline || f.Type == "textarea")
                        {
                            <textarea class="form-input" style="margin-top:8px;min-height:92px"
                                      placeholder="@f.Placeholder"
                                      @oninput="(e) => OnFieldInput(e, f.Name)">@GetFieldValue(f.Name)</textarea>
                        }
                        else
                        {
                            <input class="form-input" type="text" style="margin-top:8px"
                                   placeholder="@f.Placeholder"
                                   value="@GetFieldValue(f.Name)"
                                   @oninput="(e) => OnFieldInput(e, f.Name)" />
                        }
                    </div>
                }
            }

            <div class="form-group">
                <label class="form-label">Укажите название документа:</label>
                <input class="form-input" type="text" placeholder="Например: Отчет_по_продажам.docx" @bind="fileName" />
                @if (!string.IsNullOrWhiteSpace(PickedFileName))
                {
                    <div style="margin-top:8px;color:var(--text-tertiary);font-size:12px">
                        Выбран файл: @PickedFileName (@PickedFileSizeText)
                    </div>
                }
            </div>

            <div class="form-group" style="margin-top: 12px;">
                <div class="form-label" style="margin-bottom:8px">Личная подпись:</div>
                <label style="display:flex;align-items:center;gap:8px;color:var(--text-secondary);font-size:13px">
                    <input type="radio" name="personalSign" checked="@requiresPersonalSign" @onchange="() => requiresPersonalSign = true" />
                    Требуется
                </label>
                <label style="display:flex;align-items:center;gap:8px;color:var(--text-secondary);font-size:13px;margin-top:6px">
                    <input type="radio" name="personalSign" checked="@(!requiresPersonalSign)" @onchange="() => requiresPersonalSign = false" />
                    Не требуется
                </label>
            </div>

            <div class="form-group" style="margin-top: 12px;">
                <div class="form-label" style="margin-bottom:8px">Документ назначен:</div>
                <label style="display:flex;align-items:center;gap:8px;color:var(--text-secondary);font-size:13px">
                    <input type="radio" name="assignMode" checked="@(assignMode==AssignMode.Users)" @onchange="() => SetAssignMode(AssignMode.Users)" />
                    Одному человеку / группе людей
                </label>
                <label style="display:flex;align-items:center;gap:8px;color:var(--text-secondary);font-size:13px;margin-top:6px">
                    <input type="radio" name="assignMode" checked="@(assignMode==AssignMode.Department)" @onchange="() => SetAssignMode(AssignMode.Department)" />
                    Отделу
                </label>
            </div>

            @if (assignMode == AssignMode.Users)
            {
                <div class="form-group" style="margin-top: 12px;">
                    <label class="form-label">Укажите подписанта:</label>
                    <div class="signers-search" style="margin-top: 8px;">
                        <input type="text" placeholder="Поиск сотрудника..." @bind="signerSearch" @bind:event="oninput" />
                    </div>
                    @foreach (var s in GetFilteredSigners())
                    {
                        <div class="signer-option @(selectedSigners.Contains(s.Id) ? "selected" : "")"
                             style="margin-top: 10px;"
                             @onclick="() => ToggleSigner(s.Id)">
                            <div class="signer-avatar">@s.Initials</div>
                            <div class="signer-details">
                                <div class="signer-details-name">@s.FullName</div>
                                <div class="signer-details-dept">@s.Department</div>
                            </div>
                            <div class="signer-check"></div>
                        </div>
                    }
                </div>

                <div class="form-group">
                    <label class="form-label">Выбраны:</label>
                    <div class="detail-info-block" style="padding: 10px 12px;">
                        @foreach (var s in SelectedSignerLabels)
                        {
                            <div style="color:var(--text-secondary);font-size:13px;line-height:1.6">@s</div>
                        }
                        @if (SelectedSignerLabels.Count == 0)
                        {
                            <div style="color:var(--text-secondary);font-size:13px">—</div>
                        }
                    </div>
                </div>
            }
            else
            {
                <div class="form-group" style="margin-top: 12px;">
                    <label class="form-label">Укажите подписанта:</label>
                    <select class="form-input" style="margin-top:8px" @bind="selectedDepartmentId">
                        <option value="">Выберите отдел...</option>
                        @foreach (var d in departments)
                        {
                            <option value="@d.Id">@d.Name</option>
                        }
                    </select>
                </div>
            }

            <div class="wizard-actions">
                <button class="btn btn-maroon" @onclick="GoConfirm">Далее</button>
            </div>
        </div>
    }

    @* Step 4: Confirm (like slide 3) *@
    @if (currentStep == 4)
    {
        <p class="wizard-subtitle">@SelectedTemplateName | Подтверждение данных</p>
        <div class="confirm-shell">
            <div class="confirm-card">
                <div class="confirm-header">
                    <div class="confirm-title">Проверь данные перед отправкой</div>
                    <div class="confirm-sub">@SelectedTemplateName</div>
                </div>

                <div class="confirm-grid">
                    <section class="confirm-section">
                        <div class="confirm-section-title">
                            <img src="icons/document.png" alt="" class="confirm-ico" />
                            Файл
                        </div>
                        <div class="confirm-row">
                            <div class="confirm-label">Название</div>
                            <div class="confirm-value">@fileName</div>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(PickedFileName))
                        {
                            <div class="confirm-row" style="margin-top:8px">
                                <div class="confirm-label">Размер</div>
                                <div class="confirm-value">@PickedFileSizeText</div>
                            </div>
                            <div class="confirm-row" style="margin-top:6px">
                                <div class="confirm-label">Расширение</div>
                                <div class="confirm-value">@PickedFileExt</div>
                            </div>
                        }
                    </section>

                    <section class="confirm-section">
                        <div class="confirm-section-title">
                            <img src="icons/signing.png" alt="" class="confirm-ico" />
                            Настройки
                        </div>

                        <div class="confirm-chips">
                            <span class="confirm-chip @(requiresPersonalSign ? "on" : "off")">
                                Личная подпись: @(requiresPersonalSign ? "Требуется" : "Не требуется")
                            </span>
                            <span class="confirm-chip on">
                                Назначение: @(assignMode == AssignMode.Department ? "Отдел" : "Группа людей")
                            </span>
                        </div>
                    </section>

                    <section class="confirm-section confirm-section--wide">
                        <div class="confirm-section-title">
                            <img src="icons/profile.png" alt="" class="confirm-ico" />
                            Подписанты
                        </div>

                        <div class="confirm-list">
                            @foreach (var s in ConfirmSignersList)
                            {
                                <div class="confirm-list-item">@s</div>
                            }
                            @if (ConfirmSignersList.Count == 0)
                            {
                                <div class="confirm-list-empty">—</div>
                            }
                        </div>
                    </section>
                </div>
            </div>

            <div class="confirm-actions">
                <button class="btn btn-green" disabled="@isSaving" @onclick="SubmitDocument">
                    @if (isSaving)
                    {
                        <span class="mpk-btn-loading"><span class="mpk-spinner mpk-spinner--sm" aria-hidden="true"></span><span>Отправляем…</span></span>
                    }
                    else
                    {
                        <span>Отправить</span>
                    }
                </button>
                <button class="btn btn-secondary" disabled="@isSaving" @onclick="() => currentStep = 3">Изменить</button>
                <button class="btn btn-red" disabled="@isSaving" @onclick="CancelAndExit">Отменить</button>
            </div>
        </div>
    }
    }
</div>

@if (showLeaveDraftModal)
{
    <div class="modal-overlay" @onclick="StayOnLeaveDraftDialog">
        <div class="modal-card" @onclick:stopPropagation="true">
            <div class="modal-header">Сохранить черновик?</div>
            <div class="modal-body" style="text-align:center;color:var(--text-secondary);font-size:var(--font-size-sm);line-height:1.5">
                @if (selectedTemplateId is not null)
                {
                    <span>Текущий прогресс мастера будет сохранён на сервере как черновик (включая шаг).</span>
                }
                else
                {
                    <span>Будет сохранена только выбранная категория на этом устройстве — тип документа ещё не выбран.</span>
                }
                @if (!string.IsNullOrWhiteSpace(leaveModalError))
                {
                    <div style="margin-top:12px;color:#f0a0a0">@leaveModalError</div>
                }
            </div>
            <div class="modal-footer" style="flex-wrap:wrap">
                <button type="button" class="btn btn-secondary" disabled="@leaveChoiceBusy" @onclick="StayOnLeaveDraftDialog">Остаться</button>
                <button type="button" class="btn btn-red" disabled="@leaveChoiceBusy" @onclick="DiscardAndLeaveWizardAsync">Не сохранять</button>
                <button type="button" class="btn btn-green" disabled="@leaveChoiceBusy" @onclick="SaveAndLeaveWizardAsync">Сохранить</button>
            </div>
        </div>
    </div>
}

@* Back button *@
<button class="wizard-back" @onclick="GoBack">
    <img src="icons/full_arrow_left.png" alt="" style="width:20px;height:20px;opacity:1.0;filter:brightness(0) invert(1)" />
</button>

<OtpConfirmModal IsVisible="showOtp"
                 DocumentName="@fileName"
                 PhoneHint="@otpPhoneHint"
                 OnClose="CloseOtp"
                 OnConfirm="OnOtpConfirmCreate" />

@code {
    private int currentStep = 0;
    private bool isLoading;
    private bool isSaving;
    private string? loadError;
    private bool showOtp;
    private string otpPhoneHint = "";
    private string? otpCode;
    private int? _draftDocumentId;
    private bool _suppressDraftSave;
    private bool _resumeInProgress;
    private bool _draftSaveInFlight;
    private IDisposable? _locationChangingRegistration;
    private int? _pendingResumeDraftId;
    private const string PrecatStorageKey = "mpk.createWizard.precat.v1";

    private bool showLeaveDraftModal;
    private string? _leaveNavigationTarget;
    private bool leaveChoiceBusy;
    private string? leaveModalError;

    private int? meId;
    private string? meName;
    private string? meDept;

    private string? selectedCategory;
    private int? selectedTemplateId;
    private string fileName = "";
    private DateTime docDate = DateTime.Now;
    private string docNote = "";
    private string signerSearch = "";
    private HashSet<int> selectedSigners = new();

    private bool requiresPersonalSign = true;
    private AssignMode assignMode = AssignMode.Users;
    private int? selectedDepartmentId;

    private record TemplateOption(int Id, string Name, string? Category);
    private List<TemplateOption> templates = new();

    private record SchemaField(string Name, string Label, string Type, bool Required, List<string>? Options, string? Placeholder, bool Multiline);
    private List<SchemaField> schemaFields = new();
    private Dictionary<string, object?> content = new();

    private ElementReference _dropZoneRef;
    private IJSObjectReference? _dropModule;
    private IJSObjectReference? _dropDisposeHandle;
    private DotNetObjectReference<CreateDocument>? _dotNetRef;
    private bool _fileDropSessionAttached;
    private int _dragDepth;
    private bool _dragOverFile;
    private Action<string, long>? _registeredHostDrop;

    private record SignerOption(int Id, string FullName, string Department, string Initials);
    private List<SignerOption> allSigners = new();
    private record DepartmentOption(int Id, string Name);
    private List<DepartmentOption> departments = new();

    private enum AssignMode { Users, Department }

    private string TitleText => currentStep switch
    {
        0 => "Создание нового документа",
        1 => "Создание нового документа",
        2 => "Создание нового документа",
        _ => "Отправка документа",
    };

    private string SelectedTemplateName => templates.FirstOrDefault(x => x.Id == selectedTemplateId)?.Name ?? "Документ";

    private List<string> Categories => templates
        .Select(t => t.Category)
        .Where(c => !string.IsNullOrWhiteSpace(c))
        .Select(c => c!)
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .OrderBy(x => x)
        .ToList();

    private List<TemplateOption> TemplatesInCategory => templates
        .Where(t => !string.IsNullOrWhiteSpace(selectedCategory) &&
                    string.Equals(t.Category, selectedCategory, StringComparison.OrdinalIgnoreCase))
        .ToList();

    private List<string> SelectedSignerLabels => selectedSigners
        .Select(id => allSigners.FirstOrDefault(s => s.Id == id))
        .Where(s => s is not null)
        .Select(s => $"{s!.FullName} ({s.Department})")
        .ToList();

    private List<string> ConfirmSignersList
    {
        get
        {
            var list = new List<string>();
            if (meId is not null)
                list.Add($"{(meName ?? "Вы")} ({(meDept ?? "—")}) — Создатель");

            if (assignMode == AssignMode.Department)
            {
                list.Add($"Отдел: {departments.FirstOrDefault(d => d.Id == selectedDepartmentId)?.Name ?? "—"}");
                return list;
            }

            list.AddRange(SelectedSignerLabels);
            return list;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        _pendingResumeDraftId = TryParseDraftIdFromUri(Navigation.Uri);
        try
        {
            var st = await AuthStateProvider.GetAuthenticationStateAsync();
            var u = st.User;
            var idStr = u.FindFirst(ClaimTypes.NameIdentifier)?.Value;
            if (int.TryParse(idStr, out var id))
                meId = id;
            meName = u.Identity?.Name;
        }
        catch
        {
            // ignore
        }
        try
        {
            var me = await AuthApi.MeAsync();
            otpPhoneHint = PhoneDisplay.MaskRu(me.phone_number);
        }
        catch
        {
            otpPhoneHint = "";
        }
        await LoadAsync();
        await TryRestorePrecategoryFromStorageAsync();
        if (_pendingResumeDraftId is int resumeId)
            await ResumeDraftFromServerAsync(resumeId);

        _locationChangingRegistration?.Dispose();
        _locationChangingRegistration = Navigation.RegisterLocationChangingHandler(OnLocationChangingAsync);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (currentStep == 2)
        {
            _registeredHostDrop ??= OnHostFileFromNative;
            HostFileDropHub.Callback = _registeredHostDrop;
            if (!_fileDropSessionAttached)
            {
                await EnsureFileDropAsync();
                _fileDropSessionAttached = true;
            }
        }
        else
        {
            ClearHostFileDropCallback();
            if (_fileDropSessionAttached)
            {
                await TeardownFileDropAsync();
                _fileDropSessionAttached = false;
            }
        }
    }

    private async Task LoadAsync()
    {
        isLoading = true;
        loadError = null;
        try
        {
            var t = await DocsApi.ListTemplatesAsync(activeOnly: true);
            templates = t.Select(x => new TemplateOption(x.id, x.name, x.category ?? InferCategoryFromName(x.name))).ToList();

            var u = await DocsApi.ListUsersAsync(activeOnly: true);
            allSigners = u
                .Where(x => meId is null || x.id != meId.Value) // нельзя отправлять самому себе на подпись
                .Select(x => new SignerOption(
                    x.id,
                    x.full_name,
                    x.department ?? "—",
                    BuildInitials(x.full_name)))
                .ToList();
            if (meId is not null)
            {
                // "me" мы убрали из allSigners, поэтому ищем по исходному списку u
                var me = u.FirstOrDefault(x => x.id == meId.Value);
                if (me is not null)
                {
                    meName = me.full_name;
                    meDept = me.department ?? "—";
                }
            }

            var deps = await DocsApi.ListDepartmentsAsync(activeOnly: true);
            departments = deps.Select(d => new DepartmentOption(d.id, d.name)).ToList();
        }
        catch
        {
            loadError = "Не удалось загрузить шаблоны/пользователей. Проверь, что API запущено.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void FillSchemaFieldsFromFormSchema(TemplateDetailDto detail)
    {
        schemaFields = new();
        if (detail.form_schema.TryGetValue("fields", out var fieldsObj) && fieldsObj is JsonElement je && je.ValueKind == JsonValueKind.Array)
        {
            foreach (var el in je.EnumerateArray())
            {
                var name = el.TryGetProperty("name", out var n) ? n.GetString() : null;
                if (string.IsNullOrWhiteSpace(name)) continue;
                var label = el.TryGetProperty("label", out var l) ? (l.GetString() ?? name) : name;
                var type = el.TryGetProperty("type", out var t) ? (t.GetString() ?? "string") : "string";
                var required = el.TryGetProperty("required", out var r) && r.ValueKind == JsonValueKind.True;
                var placeholder = el.TryGetProperty("placeholder", out var p) ? p.GetString() : null;
                var multiline = el.TryGetProperty("multiline", out var ml) && ml.ValueKind == JsonValueKind.True;

                List<string>? options = null;
                if (el.TryGetProperty("options", out var opt) && opt.ValueKind == JsonValueKind.Array)
                {
                    options = opt.EnumerateArray()
                        .Where(x => x.ValueKind == JsonValueKind.String)
                        .Select(x => x.GetString() ?? "")
                        .Where(x => !string.IsNullOrWhiteSpace(x))
                        .ToList();
                    if (options.Count == 0) options = null;
                }

                schemaFields.Add(new SchemaField(name!, label!, type, required, options, placeholder, multiline));
            }
        }
    }

