    private static string? InferCategoryFromName(string? templateName)
    {
        if (string.IsNullOrWhiteSpace(templateName)) return null;
        var n = templateName.Trim();
        if (n.StartsWith("Отчет", StringComparison.OrdinalIgnoreCase)) return "Отчет";
        if (n.StartsWith("Приказ", StringComparison.OrdinalIgnoreCase)) return "Приказ";
        return null;
    }

    private static string HumanizeFieldName(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "Поле";
        // docNumber -> Doc Number, report_type -> Report Type
        var s = name.Replace("_", " ").Trim();
        var chars = new List<char>(s.Length + 8);
        for (var i = 0; i < s.Length; i++)
        {
            var c = s[i];
            if (i > 0 && char.IsUpper(c) && char.IsLetterOrDigit(s[i - 1]) && !char.IsWhiteSpace(s[i - 1]))
                chars.Add(' ');
            chars.Add(c);
        }
        var r = new string(chars.ToArray()).Trim();
        return char.ToUpperInvariant(r[0]) + r[1..];
    }

    private static string GetUiLabel(SchemaField f)
    {
        // Если backend не дал label — делаем человекочитаемо + небольшой словарь
        var label = string.IsNullOrWhiteSpace(f.Label) || f.Label == f.Name ? HumanizeFieldName(f.Name) : f.Label;
        return f.Name switch
        {
            "docNumber" or "documentNumber" => "Номер документа",
            "reportType" or "report_kind" or "reportKind" => "Тип отчёта",
            "title" => "Название",
            _ => label,
        };
    }

    private static string BuildInitials(string fullName)
    {
        var parts = fullName.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 0) return "—";
        var a = parts[0].Length > 0 ? parts[0][0].ToString() : "";
        var b = parts.Length > 1 && parts[1].Length > 0 ? parts[1][0].ToString() : "";
        return (a + b).ToUpperInvariant();
    }

    private Dictionary<string, object?> BuildContent()
    {
        var c = new Dictionary<string, object?>(content);
        if (!string.IsNullOrWhiteSpace(fileName)) c["fileName"] = fileName.Trim();
        // если у типа документа есть поле title — заполняем его тем же значением
        if (!string.IsNullOrWhiteSpace(fileName) &&
            schemaFields.Any(x => string.Equals(x.Name, "title", StringComparison.OrdinalIgnoreCase)) &&
            !c.ContainsKey("title"))
        {
            c["title"] = fileName.Trim();
        }
        if (!string.IsNullOrWhiteSpace(PickedFileExt)) c["fileExt"] = PickedFileExt;
        if (PickedFileSizeBytes is not null) c["fileSize"] = PickedFileSizeBytes.Value;
        c["docDate"] = docDate.ToString("yyyy-MM-dd");
        if (!string.IsNullOrWhiteSpace(docNote)) c["note"] = docNote.Trim();
        c["requiresPersonalSign"] = requiresPersonalSign;
        c["assignMode"] = assignMode == AssignMode.Department ? "department" : "users";
        if (assignMode == AssignMode.Department && selectedDepartmentId is int depId)
            c["signerDepartmentId"] = depId;
        if (!string.IsNullOrWhiteSpace(otpCode)) c["otpCode"] = otpCode;
        return c;
    }

    private async Task SaveDraft()
    {
        if (selectedTemplateId is null) return;
        if (isSaving) return;
        isSaving = true;
        loadError = null;
        try
        {
            var payload = BuildDraftContentForApi();
            int docId;
            if (_draftDocumentId is int existingId)
            {
                await DocsApi.UpdateDraftContentAsync(existingId, payload);
                docId = existingId;
            }
            else
            {
                var res = await DocsApi.CreateDocumentAsync(
                    selectedTemplateId.Value,
                    payload,
                    selectedSigners.ToList(),
                    signerDepartmentId: assignMode == AssignMode.Department ? selectedDepartmentId : null,
                    saveAsDraft: true);
                docId = res.document_id;
                _draftDocumentId = docId;
            }

            await UploadAttachmentIfNeededAsync(docId);
            await ClearPrecategoryStorageAsync();
            _suppressDraftSave = true;
            Navigation.NavigateTo($"/document/{docId}?from=create", replace: true);
        }
        catch
        {
            loadError = "Не удалось сохранить черновик.";
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task SubmitDocument()
    {
        loadError = null;
        if (selectedTemplateId is null) { loadError = "Не выбран тип документа."; return; }
        if (string.IsNullOrWhiteSpace(fileName)) { loadError = "Укажи название документа (имя файла)."; return; }
        if (assignMode == AssignMode.Users && selectedSigners.Count == 0) { loadError = "Укажи хотя бы одного подписанта."; return; }
        if (assignMode == AssignMode.Department && selectedDepartmentId is null) { loadError = "Выбери отдел."; return; }
        if (requiresPersonalSign && string.IsNullOrWhiteSpace(otpCode))
        {
            try
            {
                await AuthApi.SendOtpAsync();
            }
            catch (Exception ex)
            {
                loadError = $"Не удалось отправить SMS с кодом: {ex.Message}";
                return;
            }
            showOtp = true;
            return;
        }
        if (isSaving) return;
        isSaving = true;
        try
        {
            var signerIds = selectedSigners.ToList();
            if (requiresPersonalSign && meId is not null && !signerIds.Contains(meId.Value))
                signerIds.Insert(0, meId.Value);
            var res = await DocsApi.CreateDocumentAsync(
                selectedTemplateId.Value,
                BuildContent(),
                signerIds,
                signerDepartmentId: assignMode == AssignMode.Department ? selectedDepartmentId : null,
                saveAsDraft: false);
            await UploadAttachmentIfNeededAsync(res.document_id);
            _suppressDraftSave = true;
            Navigation.NavigateTo($"/document/{res.document_id}?from=create", replace: true);
        }
        catch (Exception ex)
        {
            loadError = string.IsNullOrWhiteSpace(ex.Message)
                ? "Не удалось отправить документ. Проверь, что API запущено."
                : $"Не удалось отправить документ: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

