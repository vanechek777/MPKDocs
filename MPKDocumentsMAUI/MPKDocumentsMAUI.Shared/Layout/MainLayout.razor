@inherits LayoutComponentBase
@inject IJSRuntime JS
@inject IMobileShellService MobileShell
@inject NavigationManager Navigation
@implements IDisposable

<div class="app-shell @(MobileShell.IsSigningOnlyShell ? "app-shell--mobile-signing" : null)">
    @if (MobileShell.IsSigningOnlyShell)
    {
        <MobileRouteLock />
    }
    <main class="app-main">
        @Body
    </main>

    @if (!MobileShell.IsSigningOnlyShell)
    {
        <FabMenu />
    }
    <BottomNavBar />
</div>

<div id="blazor-error-ui" data-nosnippet>
    Произошла непредвиденная ошибка.
    <a href="." class="reload">Перезагрузить</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private bool _uxBootstrapped;

    protected override void OnInitialized()
    {
        Navigation.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        _ = InvokeAsync(async () => await TryScheduleLiquidGlassAsync());
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_uxBootstrapped)
        {
            _uxBootstrapped = true;
            try
            {
                await JS.InvokeVoidAsync("MPKDocuments.bootstrapUxFromStorage");
            }
            catch
            {
                /* WebView без localStorage / старый JS */
            }

            await TryScheduleLiquidGlassAsync();
        }
    }

    private async Task TryScheduleLiquidGlassAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("MPKDocuments.scheduleLiquidGlassRebuild");
        }
        catch
        {
            /* Старый JS */
        }
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= OnLocationChanged;
    }
}
