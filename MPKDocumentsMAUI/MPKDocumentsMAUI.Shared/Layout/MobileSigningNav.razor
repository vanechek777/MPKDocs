@using Microsoft.AspNetCore.Components.Routing
@inject NavigationManager Navigation
@inject IMobileShellService MobileShell
@inject MPKDocumentsMAUI.Shared.Auth.AuthService Auth
@implements IDisposable

@if (MobileShell.IsSigningOnlyShell)
{
    @if (_sheetOpen)
    {
        <button type="button" class="mpk-mobile-nav__backdrop" aria-label="Закрыть меню" @onclick="CloseSheet"></button>
        <div class="mpk-mobile-nav__sheet" @onclick:stopPropagation="true">
            <button type="button" class="mpk-mobile-nav__sheet-item" @onclick="LogoutAsync">Выйти</button>
        </div>
    }

    <nav class="mpk-mobile-nav" aria-label="Основные разделы">
        <NavLink class="mpk-mobile-nav__btn" href="/signing" Match="NavLinkMatch.Prefix" @onclick="CloseSheet">
            <img src="icons/signing.png" alt="" class="mpk-mobile-nav__ico" width="22" height="22" />
            <span>Подпись</span>
        </NavLink>
        <NavLink class="mpk-mobile-nav__btn" href="/verify-nep" Match="NavLinkMatch.Prefix" @onclick="CloseSheet">
            <img src="icons/document.png" alt="" class="mpk-mobile-nav__ico" width="22" height="22" />
            <span>НЭП</span>
        </NavLink>
        <button type="button" class="mpk-mobile-nav__btn mpk-mobile-nav__btn--ghost" @onclick="() => _sheetOpen = true" aria-haspopup="true" aria-expanded="@_sheetOpen">
            <span class="mpk-mobile-nav__more" aria-hidden="true">⋯</span>
            <span>Ещё</span>
        </button>
    </nav>
}

@code {
    private bool _sheetOpen;

    protected override void OnInitialized()
    {
        Navigation.LocationChanged += OnLoc;
    }

    private void OnLoc(object? s, LocationChangedEventArgs e) => CloseSheet();

    private void CloseSheet() => _sheetOpen = false;

    private async Task LogoutAsync()
    {
        CloseSheet();
        await Auth.LogoutAsync();
        Navigation.NavigateTo("/login", replace: true);
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= OnLoc;
    }
}
