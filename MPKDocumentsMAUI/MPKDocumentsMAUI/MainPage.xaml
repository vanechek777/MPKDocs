<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:MPKDocumentsMAUI"
             xmlns:shared="clr-namespace:MPKDocumentsMAUI.Shared;assembly=MPKDocumentsMAUI.Shared"
             x:Class="MPKDocumentsMAUI.MainPage"
             BackgroundColor="{DynamicResource PageBackgroundColor}">

    <!-- Нативный DropGestureRecognizer на BlazorWebView на WinUI давал NullReferenceException (см. dotnet/maui #24900, #26887 при WindowsPackageType=None). -->
    <BlazorWebView x:Name="blazorWebView" HostPage="wwwroot/index.html">
        <BlazorWebView.RootComponents>
            <RootComponent Selector="#app" ComponentType="{x:Type shared:Routes}" />
        </BlazorWebView.RootComponents>
    </BlazorWebView>

</ContentPage>
